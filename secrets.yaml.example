# Copy to secrets.yaml and fill in your values. Do not commit secrets.yaml.
#
# Required for all devices:
wifi_ssid: "your_wifi_ssid"
wifi_password: "your_wifi_password"

# Device-specific OTA passwords (generate random hex strings)
tv_lift_ota_password: "your_tv_lift_ota_password"
intercom_ota_password: "your_intercom_ota_password"

# Device-specific API encryption keys (from ESPHome/Home Assistant)
tv_lift_api_key: "your_tv_lift_api_key"
intercom_api_key: "your_intercom_api_key"
water_cooker_api_key: "your_water_cooker_api_key"
water_cooler_api_key: "your_water_cooler_api_key"
dishwasher_api_key: "your_dishwasher_api_key"
